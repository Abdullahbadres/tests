{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "12253191331295990238"
    }
  },
  "parameters": {
    "managedPostgresFqdn": {
      "type": "string",
      "metadata": {
        "description": "FQDN server PostgreSQL Flexible (isi dari skrip deploy; jangan hardcode nama server di repo publik)"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "southeastasia"
    },
    "dnsNameLabel": {
      "type": "string",
      "metadata": {
        "description": "Label DNS ACI (pertahankan saat update)"
      }
    },
    "backendImage": {
      "type": "string",
      "defaultValue": "gcr.io/google-samples/hello-app:1.0"
    },
    "frontendImage": {
      "type": "string",
      "defaultValue": "docker.io/library/nginx:alpine"
    },
    "useAcr": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Tarik image dari ACR privat"
      }
    },
    "acrLoginServer": {
      "type": "string",
      "defaultValue": ""
    },
    "acrUsername": {
      "type": "string",
      "defaultValue": ""
    },
    "acrPassword": {
      "type": "securestring",
      "defaultValue": ""
    },
    "laravelDbPassword": {
      "type": "securestring"
    },
    "laravelAppKey": {
      "type": "securestring"
    }
  },
  "variables": {
    "cgName": "test-fe-be-pg",
    "fqdn": "[format('{0}.{1}.azurecontainer.io', parameters('dnsNameLabel'), parameters('location'))]",
    "registryCreds": "[if(parameters('useAcr'), createArray(createObject('server', parameters('acrLoginServer'), 'username', parameters('acrUsername'), 'password', parameters('acrPassword'))), createArray())]",
    "backendEnv": [
      {
        "name": "APP_NAME",
        "value": "AI Sales Page Generator API"
      },
      {
        "name": "APP_ENV",
        "value": "production"
      },
      {
        "name": "APP_DEBUG",
        "value": "false"
      },
      {
        "name": "APP_URL",
        "value": "[format('http://{0}:8080', variables('fqdn'))]"
      },
      {
        "name": "LOG_CHANNEL",
        "value": "stderr"
      },
      {
        "name": "SESSION_DRIVER",
        "value": "cookie"
      },
      {
        "name": "CACHE_STORE",
        "value": "file"
      },
      {
        "name": "QUEUE_CONNECTION",
        "value": "sync"
      },
      {
        "name": "DB_CONNECTION",
        "value": "pgsql"
      },
      {
        "name": "DB_HOST",
        "value": "[parameters('managedPostgresFqdn')]"
      },
      {
        "name": "DB_PORT",
        "value": "5432"
      },
      {
        "name": "DB_DATABASE",
        "value": "laravel"
      },
      {
        "name": "DB_USERNAME",
        "value": "pgadmin"
      },
      {
        "name": "DB_SSLMODE",
        "value": "require"
      },
      {
        "name": "FRONTEND_URL",
        "value": "[format('http://{0}', variables('fqdn'))]"
      },
      {
        "name": "SANCTUM_STATEFUL_DOMAINS",
        "value": "[variables('fqdn')]"
      },
      {
        "name": "APP_KEY",
        "secureValue": "[parameters('laravelAppKey')]"
      },
      {
        "name": "DB_PASSWORD",
        "secureValue": "[parameters('laravelDbPassword')]"
      }
    ],
    "frontendEnv": [
      {
        "name": "NEXT_PUBLIC_API_URL",
        "value": "[format('http://{0}:8080', variables('fqdn'))]"
      }
    ]
  },
  "resources": [
    {
      "type": "Microsoft.ContainerInstance/containerGroups",
      "apiVersion": "2023-05-01",
      "name": "[variables('cgName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": "Standard",
        "osType": "Linux",
        "restartPolicy": "Always",
        "imageRegistryCredentials": "[variables('registryCreds')]",
        "ipAddress": {
          "type": "Public",
          "dnsNameLabel": "[parameters('dnsNameLabel')]",
          "ports": [
            {
              "port": 80,
              "protocol": "TCP"
            },
            {
              "port": 8080,
              "protocol": "TCP"
            }
          ]
        },
        "containers": [
          {
            "name": "test-backend",
            "properties": {
              "image": "[parameters('backendImage')]",
              "resources": {
                "requests": {
                  "cpu": "[json('1.5')]",
                  "memoryInGB": "[json('2')]"
                }
              },
              "ports": [
                {
                  "port": 8080,
                  "protocol": "TCP"
                }
              ],
              "environmentVariables": "[variables('backendEnv')]"
            }
          },
          {
            "name": "test-frontend",
            "properties": {
              "image": "[parameters('frontendImage')]",
              "resources": {
                "requests": {
                  "cpu": "[json('1.0')]",
                  "memoryInGB": "[json('1.5')]"
                }
              },
              "ports": [
                {
                  "port": 80,
                  "protocol": "TCP"
                }
              ],
              "environmentVariables": "[variables('frontendEnv')]"
            }
          }
        ]
      }
    }
  ],
  "outputs": {
    "fqdn": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ContainerInstance/containerGroups', variables('cgName')), '2023-05-01').ipAddress.fqdn]"
    },
    "ip": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ContainerInstance/containerGroups', variables('cgName')), '2023-05-01').ipAddress.ip]"
    },
    "dnsNameLabelOut": {
      "type": "string",
      "value": "[parameters('dnsNameLabel')]"
    },
    "containerGroupName": {
      "type": "string",
      "value": "[variables('cgName')]"
    },
    "laravelDbHost": {
      "type": "string",
      "value": "[parameters('managedPostgresFqdn')]"
    },
    "laravelDbPort": {
      "type": "string",
      "value": "5432"
    },
    "laravelDbDatabase": {
      "type": "string",
      "value": "laravel"
    },
    "laravelDbUsername": {
      "type": "string",
      "value": "pgadmin"
    },
    "hint": {
      "type": "string",
      "value": "Backend :8080, frontend :80. DB = Flexible PostgreSQL (SSL)."
    }
  }
}